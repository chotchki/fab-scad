#!/usr/bin/env bash
# Pre-push preflight — mirror the CI fmt + compile gates so a red push (the web-v0.15.0 fmt miss that
# reddened CI *after* the tag was live) never leaves the machine. Fast enough to run every push from a warm
# cache; bypass with `git push --no-verify` when you deliberately need to (a WIP branch, a docs-only push).
#
# Enable once per clone (git won't trust a repo hooks dir automatically):
#   git config core.hooksPath .githooks
set -euo pipefail

# Run from the repo root regardless of where git invoked us.
cd "$(git rev-parse --show-toplevel)"

echo "pre-push: cargo fmt --check …"
cargo fmt --all -- --check

echo "pre-push: cargo check …"
cargo check --workspace --all-targets

echo "pre-push: OK ✓"
